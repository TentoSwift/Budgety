    },
    "開始 %@ · 終了 %@ · 最終生成 %@": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "new",
            "value": "開始 %1$@ · 終了 %2$@ · 最終生成 %3$@"
