            "value": "%1$@さんが「%2$@」であなたに %3$@ を割り当てました"
          }
        }
      }
    },
    "%@として記録できるのはこのシートのオーナー・参加者・バーチャルメンバーです。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only the owner, participants, and virtual members of this sheet can be recorded as %@."
