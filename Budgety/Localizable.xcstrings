            "state": "translated",
            "value": "Apply"
          }
        }
      }
    },
    "金額": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Amount"
          }
        }
      }
    },
    "金額は 0 より大きい値を指定してください。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enter an amount greater than 0."
          }
        }
      }
    },
