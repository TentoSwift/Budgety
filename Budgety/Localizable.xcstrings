    "開始日": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start date"
          }
        }
      }
    },
    "開始日から指定の頻度で、過去〜今日までの未生成分を自動でシートに追加します。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the start date and at the chosen frequency, ungenerated entries from the past up to today are added to the sheet automatically."
          }
        }
      }
    },
